      <output id="output3" name="mensaje" typeRef="string" />
      <rule id="_9B76A482-8E37-4299-86EA-E5A9DF0F0F8E">
        <inputEntry id="_A95D97C1-AA5A-46A6-A4C3-4F4BF7708F52">
          <text>&quot;TEMPORADA&quot;</text>
        </inputEntry>
        <inputEntry id="_2DD82462-ABD2-4861-9EF0-343E121C5C27">
          <text>&gt;= 90</text>
        </inputEntry>
        <inputEntry id="_D14427BA-3104-4133-8666-BAD9A45A82E5">
          <text>&gt;= 40</text>
        </inputEntry>
        <outputEntry id="_645631E3-C226-4CE1-BEB0-5BEF33231F09">
          <text>&quot;A&quot;</text>
        </outputEntry>
        <outputEntry id="_CF548199-D51F-4747-AE91-1414CA3CEFB7">
          <text>15.0</text>
        </outputEntry>
        <outputEntry id="_1FBCBEBC-5AB7-457F-B704-BF88E105E3F1">
          <text>&quot;Bono temporada alta completo: 15%&quot;</text>
        </outputEntry>
      </rule>
      <rule id="_F324E522-856C-45FF-AD2A-D9577D6DE55F">
        <inputEntry id="_EE806B58-C6FF-4312-82BC-5A40EBE008BB">
          <text>&quot;TEMPORADA&quot;</text>
        </inputEntry>
        <inputEntry id="_A29A2EAB-F9B8-4B70-87AC-C6C22D20DAD3">
          <text>[60..89]</text>
        </inputEntry>
        <inputEntry id="_1CD5B52A-35F7-462B-9BCB-8577D26EF8E1">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_0E4B7A1D-D411-470F-865F-3C4B0A05ED95">
          <text>&quot;B&quot;</text>
        </outputEntry>
        <outputEntry id="_F6F34DC9-95E5-4EB8-AC33-645A869BC14A">
          <text>8.0</text>
        </outputEntry>
        <outputEntry id="_8F29570F-70D1-46FB-8F39-3170EAE44D09">
          <text>&quot;Bono temporada alta parcial: 8%&quot;</text>
        </outputEntry>
      </rule>
      <rule id="_5D7E0A7A-AA14-4144-A488-205FE0C06AF3">
        <inputEntry id="_3D8E355A-D1D3-41B8-891E-5B523F60B3EE">
          <text>&quot;INDEFINIDO&quot;</text>
        </inputEntry>
        <inputEntry id="_13046D5D-6709-495E-94C2-FE55A1365A7E">
          <text>&gt;= 180</text>
        </inputEntry>
        <inputEntry id="_0E018979-0483-4BC4-8A70-415CB9324DCD">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_8C0C8BD8-78ED-47BC-9764-083620CA1EA6">
          <text>&quot;C&quot;</text>
        </outputEntry>
        <outputEntry id="_CABF9E61-408E-4DF3-B15A-8BA9107A21AB">
          <text>5.0</text>
        </outputEntry>
        <outputEntry id="_E57F0921-3642-4B6D-A528-6FF85157A00E">
          <text>&quot;Bono permanencia contrato indefinido: 5%&quot;</text>
        </outputEntry>
      </rule>
      <rule id="_5F44FC59-195E-41BE-99D1-8458B0F34AEB">
        <inputEntry id="_F579C89B-5840-4E0F-B471-508C1C41EE43">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_0C225D14-503C-44DF-B8F5-3A5DC36973BF">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_6E0C88D5-F1B6-44AC-AA90-1F1EE2B6369C">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_C54186A5-0577-4D69-ABA5-BCBE7462291C">
          <text>&quot;SIN_BONO&quot;</text>
        </outputEntry>
        <outputEntry id="_087FCAB2-468D-448A-BC0B-EBB98197243B">
          <text>0.0</text>
        </outputEntry>
        <outputEntry id="_45EE3134-9000-4A5A-BF01-A242C4203F15">
          <text>&quot;No cumple criterios para bono en este período&quot;</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
